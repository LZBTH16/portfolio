---
const base = import.meta.env.BASE_URL;
---

<header class="site-header" data-nav-state="full">
  <nav class="site-nav" aria-label="Primary">
    <a class="site-brand" href={base} aria-label="Go to home page">
      <img class="site-brand-image" src={`${base}portfolio-logo.png`} alt="Profile" loading="lazy" decoding="async" />
      <span class="site-title">Elizabeth's Portfolio</span>
    </a>

    <div class="site-nav-links">
      <a href={base}>Home</a>
      <a href={`${base}about`}>About</a>
      <a href={`${base}projects`}>Projects</a>
    </div>
  </nav>
</header>

<script is:inline>
  const siteHeader = document.querySelector(".site-header");

  if (siteHeader) {
    let lastScrollY = window.scrollY;

    const onScroll = () => {
      const currentScrollY = window.scrollY;

      if (currentScrollY <= 8) {
        siteHeader.dataset.navState = "full";
      } else if (currentScrollY > lastScrollY + 2) {
        siteHeader.dataset.navState = "compact";
      } else if (currentScrollY < lastScrollY - 2) {
        siteHeader.dataset.navState = "full";
      }

      lastScrollY = currentScrollY;
    };

    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();
  }
</script>