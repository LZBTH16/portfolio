---
import Navbar from "../components/Navbar.astro";
import "../styles/global.css";

const { title = "Elizabeth's Portfolio" } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="icon" type="image/png" href={`${base}portfolio-logo.png`} />
  </head>
  <body>
    <main>
      <Navbar/>
      <slot />
    </main>
    <script>
      const initProjectImageViewer = () => {
        if (document.querySelector('.project-image-viewer')) return;

        const images = Array.from(document.querySelectorAll<HTMLImageElement>('.project-screenshot-card .project-screenshot-image'));
        if (!images.length) return;

        const viewer = document.createElement('div');
        viewer.className = 'project-image-viewer';
        viewer.hidden = true;
        viewer.innerHTML = `
          <div class="project-image-viewer-panel" role="dialog" aria-modal="true" aria-label="Project image viewer">
            <div class="project-image-viewer-header">
              <p class="project-image-viewer-caption"></p>
              <button type="button" class="project-image-viewer-close" aria-label="Close image viewer">Close</button>
            </div>
            <div class="project-image-viewer-frame">
              <button type="button" class="project-image-viewer-nav project-image-viewer-prev" aria-label="Previous image">‹</button>
              <img class="project-image-viewer-image" alt="" />
              <button type="button" class="project-image-viewer-nav project-image-viewer-next" aria-label="Next image">›</button>
            </div>
          </div>
        `;

        document.body.appendChild(viewer);

        const viewerImage = viewer.querySelector('.project-image-viewer-image') as HTMLImageElement | null;
        const caption = viewer.querySelector('.project-image-viewer-caption') as HTMLParagraphElement | null;
        const closeButton = viewer.querySelector('.project-image-viewer-close') as HTMLButtonElement | null;
        const prevButton = viewer.querySelector('.project-image-viewer-prev') as HTMLButtonElement | null;
        const nextButton = viewer.querySelector('.project-image-viewer-next') as HTMLButtonElement | null;

        if (!viewerImage || !caption || !closeButton || !prevButton || !nextButton) {
          return;
        }

        const resolvedViewerImage = viewerImage as HTMLImageElement;
        const resolvedCaption = caption as HTMLParagraphElement;
        const resolvedCloseButton = closeButton as HTMLButtonElement;
        const resolvedPrevButton = prevButton as HTMLButtonElement;
        const resolvedNextButton = nextButton as HTMLButtonElement;

        let currentIndex = 0;
        let lastTrigger: HTMLElement | null = null;

        const getCaptionText = (image: HTMLImageElement) => {
          const figureCaption = image.closest('figure')?.querySelector('figcaption')?.textContent?.trim();
          return figureCaption || image.alt || '';
        };

        const updateViewer = () => {
          const image = images[currentIndex];
          resolvedViewerImage.src = image.src;
          resolvedViewerImage.alt = image.alt || '';
          resolvedCaption.textContent = getCaptionText(image);
        };

        const openViewer = (index: number, trigger: HTMLElement | null) => {
          currentIndex = index;
          lastTrigger = trigger || null;
          updateViewer();
          viewer.hidden = false;
          document.body.classList.add('project-viewer-open');
          resolvedCloseButton.focus();
        };

        const closeViewer = () => {
          viewer.hidden = true;
          document.body.classList.remove('project-viewer-open');
          if (lastTrigger) {
            lastTrigger.focus();
          }
        };

        const goToImage = (nextIndex: number) => {
          currentIndex = (nextIndex + images.length) % images.length;
          updateViewer();
        };

        images.forEach((image, index) => {
          image.tabIndex = 0;
          image.setAttribute('role', 'button');
          image.setAttribute('aria-label', `Open ${getCaptionText(image)} in a larger viewer`);

          image.addEventListener('click', () => {
            openViewer(index, image);
          });
          image.addEventListener('keydown', (event) => {
            const keyboardEvent = event as KeyboardEvent;

            if (keyboardEvent.key === 'Enter' || keyboardEvent.key === ' ') {
              keyboardEvent.preventDefault();
              openViewer(index, image);
            }
          });
        });

        resolvedCloseButton.addEventListener('click', closeViewer);
        resolvedPrevButton.addEventListener('click', () => goToImage(currentIndex - 1));
        resolvedNextButton.addEventListener('click', () => goToImage(currentIndex + 1));

        viewer.addEventListener('click', (event) => {
          if (event.target === viewer) {
            closeViewer();
          }
        });

        document.addEventListener('keydown', (event) => {
          if (viewer.hidden) return;

          if (event.key === 'Escape') {
            event.preventDefault();
            closeViewer();
          } else if (event.key === 'ArrowLeft') {
            event.preventDefault();
            goToImage(currentIndex - 1);
          } else if (event.key === 'ArrowRight') {
            event.preventDefault();
            goToImage(currentIndex + 1);
          }
        });
      };

      const initMobilePageToc = () => {
        document.querySelectorAll('.mobile-toc-open').forEach((button) => button.remove());

        const toc = document.querySelector(
          '.about-page .about-toc, .projects-page .projects-toc, .project-detail-page .project-detail-toc'
        );

        if (!(toc instanceof HTMLElement)) return;

        toc.classList.add('mobile-floating-toc');

        if (!toc.id) {
          toc.id = `page-toc-${Math.random().toString(36).slice(2, 8)}`;
        }

        let closeButton = toc.querySelector('.mobile-toc-close');
        if (!(closeButton instanceof HTMLButtonElement)) {
          const createdCloseButton = document.createElement('button') as HTMLButtonElement;
          createdCloseButton.type = 'button';
          createdCloseButton.className = 'mobile-toc-close';
          createdCloseButton.setAttribute('aria-label', 'Close on this page menu');
          createdCloseButton.textContent = 'x';
          toc.prepend(createdCloseButton);
          closeButton = createdCloseButton;
        }

        const resolvedCloseButton = closeButton as unknown as HTMLButtonElement;

        const openButton = document.createElement('button');
        openButton.type = 'button';
        openButton.className = 'mobile-toc-open';
        openButton.setAttribute('aria-label', 'Open on this page menu');
        openButton.setAttribute('aria-controls', toc.id);
        openButton.textContent = '#';
        document.body.appendChild(openButton);

        const closeMenu = () => {
          toc.classList.remove('is-open');
          openButton.setAttribute('aria-expanded', 'false');
        };

        const openMenu = () => {
          toc.classList.add('is-open');
          openButton.setAttribute('aria-expanded', 'true');
          resolvedCloseButton.focus();
        };

        const updateAnchorPosition = () => {
          const header = document.querySelector('.site-header');
          let top = 88;

          if (header instanceof HTMLElement) {
            const headerBottom = Math.round(header.getBoundingClientRect().bottom);
            top = Math.max(72, headerBottom + 8);
          }

          const topValue = `${top}px`;
          openButton.style.top = topValue;
          toc.style.top = topValue;
        };

        const syncForViewport = () => {
          const isMobile = window.matchMedia('(max-width: 900px)').matches;

          updateAnchorPosition();

          if (!isMobile) {
            toc.classList.remove('is-open');
            openButton.hidden = true;
            return;
          }

          openButton.hidden = toc.classList.contains('is-open');
        };

        openButton.addEventListener('click', () => {
          openMenu();
          syncForViewport();
        });

        resolvedCloseButton.addEventListener('click', () => {
          closeMenu();
          syncForViewport();
          openButton.focus();
        });

        toc.querySelectorAll('a').forEach((link) => {
          link.addEventListener('click', () => {
            if (!window.matchMedia('(max-width: 900px)').matches) return;
            closeMenu();
            syncForViewport();
          });
        });

        window.addEventListener('resize', syncForViewport);
        window.addEventListener('scroll', updateAnchorPosition, { passive: true });
        syncForViewport();
      };

      document.addEventListener('DOMContentLoaded', initProjectImageViewer);
      document.addEventListener('DOMContentLoaded', initMobilePageToc);
      document.addEventListener('astro:page-load', initProjectImageViewer);
      document.addEventListener('astro:page-load', initMobilePageToc);
    </script>
  </body>
</html>